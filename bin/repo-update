#!/bin/bash
# Generated By: Claude Code (Claude Opus 4.6)
# Interactive batch updater for git repos that are behind origin.
#
# Usage: repo-update [--fetch] [--owner OWNER] [--dryrun] [dir...]
#   Discovers repos behind origin's default branch, presents an fzf
#   multi-select picker, then runs configured commands in each selected repo.
#
# Config: ~/.config/repo-update.json
#   Keys are paths (exact or glob with *), values are command arrays.
#   Exact path match wins over glob. No implicit commands.
#   Example: { "~/source/*": ["gcm"], "~/source/my-stuff": ["gcm", "make reconcile"] }
#
# Requires: git, fzf, jq

set -euo pipefail

CONFIG_FILE="$HOME/.config/repo-update.json"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
DIM='\033[2m'
RESET='\033[0m'

usage() {
    echo "Usage: repo-update [--fetch] [--owner OWNER] [--dryrun] [--only-toplevel] [--only-default-branch] [dir...]"
    echo ""
    echo "Interactive batch updater for git repos that are behind origin."
    echo ""
    echo "Options:"
    echo "  --fetch                fetch from all remotes before checking status"
    echo "  --owner OWNER          only check repos where origin is owned by OWNER"
    echo "  --dryrun               show what would be updated without running commands"
    echo "  --only-toplevel        exclude repos nested inside another discovered repo"
    echo "  --only-default-branch  only include repos checked out on their default branch"
    echo "  --help, -h             show this help message"
    echo ""
    echo "Directories default to those derived from config keys."
    echo "Positional dir args override config."
    echo ""
    echo "Config: $CONFIG_FILE"
}

# Get commands for a repo path. Exact match wins over directory/glob match.
# Key formats: "~/path/repo" (exact), "~/path/*" (glob), "~/path/" (trailing slash)
# Args: $1 = repo path (with ~ prefix, e.g. ~/source/foo)
get_commands() {
    local repo_path="$1"
    if [[ ! -f "$CONFIG_FILE" ]]; then
        return
    fi
    # Try exact match first
    local cmds
    cmds=$(jq -r --arg p "$repo_path" '.[$p][]? // empty' "$CONFIG_FILE" 2>/dev/null | tr -d '\r')
    if [[ -n "$cmds" ]]; then
        echo "$cmds"
        return
    fi
    # Fall back to directory match (keys ending in /* or /)
    while IFS= read -r key; do
        local pattern="${key%/\*}"
        pattern="${pattern%/}"
        if [[ "$repo_path" == "$pattern"/* ]]; then
            jq -r --arg p "$key" '.[$p][]? // empty' "$CONFIG_FILE" 2>/dev/null | tr -d '\r'
            return
        fi
    done < <(jq -r 'keys[] | select(endswith("/*") or endswith("/"))' "$CONFIG_FILE" 2>/dev/null | tr -d '\r')
}

DO_FETCH=false
FILTER_OWNER=""
DRYRUN=false
ONLY_TOPLEVEL=false
ONLY_DEFAULT_BRANCH=false
DIRS=()
while [[ $# -gt 0 ]]; do
    case "$1" in
        --fetch) DO_FETCH=true; shift ;;
        --owner) FILTER_OWNER="$2"; shift 2 ;;
        --dryrun) DRYRUN=true; shift ;;
        --only-toplevel) ONLY_TOPLEVEL=true; shift ;;
        --only-default-branch) ONLY_DEFAULT_BRANCH=true; shift ;;
        --help|-h) usage; exit 0 ;;
        *) DIRS+=("$1"); shift ;;
    esac
done

# Derive scan directories from config keys when no positional args given
if [[ ${#DIRS[@]} -eq 0 ]]; then
    if [[ -f "$CONFIG_FILE" ]]; then
        while IFS= read -r key; do
            # Strip glob/slash suffix to get the scan directory
            dir="${key%/\*}"
            dir="${dir%/}"
            # Exact path keys: scan the parent directory
            if [[ "$dir" == "$key" ]]; then
                dir="$(dirname "$dir")"
            fi
            dir="${dir/#\~/$HOME}"
            [[ -d "$dir" ]] && DIRS+=("$dir")
        done < <(jq -r 'keys[]' "$CONFIG_FILE" 2>/dev/null | tr -d '\r')
        # Deduplicate (exact path keys are children of glob dirs)
        if [[ ${#DIRS[@]} -gt 0 ]]; then
            mapfile -t DIRS < <(printf '%s\n' "${DIRS[@]}" | sort -u)
        fi
    fi
    if [[ ${#DIRS[@]} -eq 0 ]]; then
        DIRS=(~/source)
    fi
fi

for cmd in fzf jq; do
    if ! command -v "$cmd" >/dev/null 2>&1; then
        echo -e "${RED}Required command not found: $cmd${RESET}" >&2
        exit 1
    fi
done

# Discover git repos
repos=()
for dir in "${DIRS[@]}"; do
    if [[ ! -d "$dir" ]]; then
        echo -e "${RED}Directory not found: $dir${RESET}" >&2
        continue
    fi
    while IFS= read -r gitdir; do
        repos+=("$(dirname "$gitdir")")
    done < <(find "$dir" -name .git -type d 2>/dev/null | sort)
done

if [[ ${#repos[@]} -eq 0 ]]; then
    echo "No git repos found."
    exit 0
fi

if [[ "$ONLY_TOPLEVEL" == true ]]; then
    toplevel_repos=()
    for repo in "${repos[@]}"; do
        nested=false
        for other in "${repos[@]}"; do
            if [[ "$repo" != "$other" && "$repo" == "$other"/* ]]; then
                nested=true
                break
            fi
        done
        if [[ "$nested" == false ]]; then
            toplevel_repos+=("$repo")
        fi
    done
    repos=("${toplevel_repos[@]}")
fi

# Filter out worktrees, non-repos, and optionally by owner
filtered_repos=()
for repo in "${repos[@]}"; do
    if ! git -C "$repo" rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        continue
    fi
    gitdir=$(git -C "$repo" rev-parse --git-dir 2>/dev/null)
    commondir=$(git -C "$repo" rev-parse --git-common-dir 2>/dev/null)
    if [[ "$gitdir" != "$commondir" ]]; then
        continue
    fi
    if [[ -n "$FILTER_OWNER" ]]; then
        origin_url=$(git -C "$repo" remote get-url origin 2>/dev/null || echo "")
        if [[ ! "$origin_url" =~ github\.com[:/]${FILTER_OWNER}/ ]]; then
            continue
        fi
    fi
    filtered_repos+=("$repo")
done

echo "Checking ${#filtered_repos[@]} repos..."

if [[ "$DO_FETCH" == true ]]; then
    echo -ne "Fetching ${#filtered_repos[@]} repos..."
    printf '%s\0' "${filtered_repos[@]}" \
        | xargs -0 -P 8 -I {} sh -c 'git -C "$1" fetch --all --prune --tags --quiet 2>/dev/null || true' _ {}
    echo " done."
fi

# Find repos that are behind
behind_repos=()
behind_labels=()
for repo in "${filtered_repos[@]}"; do
    default_branch=""
    if git -C "$repo" rev-parse --verify --quiet origin/HEAD >/dev/null 2>&1; then
        default_branch=$(git -C "$repo" symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's|refs/remotes/origin/||')
    fi
    if [[ -z "$default_branch" ]]; then
        if git -C "$repo" rev-parse --verify --quiet origin/main >/dev/null 2>&1; then
            default_branch="main"
        elif git -C "$repo" rev-parse --verify --quiet origin/master >/dev/null 2>&1; then
            default_branch="master"
        else
            continue
        fi
    fi

    local_branch=$(git -C "$repo" rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")
    if [[ -z "$local_branch" || "$local_branch" == "HEAD" ]]; then
        continue
    fi

    if [[ "$ONLY_DEFAULT_BRANCH" == true && "$local_branch" != "$default_branch" ]]; then
        continue
    fi

    behind=$(git -C "$repo" rev-list --count "${local_branch}..origin/${default_branch}" 2>/dev/null || echo "0")
    if [[ "$behind" != "0" ]]; then
        short="${repo/#$HOME/\~}"
        behind_repos+=("$repo")
        behind_labels+=("$short ($local_branch) $behind behind")
    fi
done

if [[ ${#behind_repos[@]} -eq 0 ]]; then
    echo -e "${GREEN}All repos are up to date.${RESET}"
    exit 0
fi

echo -e "${#behind_repos[@]} repos behind origin."
echo ""

# Present fzf multi-select picker
selected_labels=$(printf '%s\n' "${behind_labels[@]}" \
    | fzf --multi \
          --header "Select repos to update (TAB to toggle, ENTER to confirm)" \
          --bind "ctrl-a:select-all" \
          --reverse) || true

if [[ -z "$selected_labels" ]]; then
    echo "No repos selected."
    exit 0
fi

# Map selected labels back to repo paths
selected_repos=()
while IFS= read -r label; do
    for i in "${!behind_labels[@]}"; do
        if [[ "${behind_labels[$i]}" == "$label" ]]; then
            selected_repos+=("${behind_repos[$i]}")
            break
        fi
    done
done <<< "$selected_labels"

clear

echo ""
echo -e "${BOLD}Updating ${#selected_repos[@]} repos...${RESET}"
echo ""

succeeded=0
failed=0
failed_repos=()
skipped_repos=()

for repo in "${selected_repos[@]}"; do
    short="${repo/#$HOME/\~}"

    echo -e "${CYAN}━━━ ${short} ━━━${RESET}"

    commands=()
    while IFS= read -r cmd; do
        [[ -n "$cmd" ]] && commands+=("$cmd")
    done < <(get_commands "$short")

    if [[ ${#commands[@]} -eq 0 ]]; then
        echo -e "  ${DIM}no commands configured, skipping${RESET}"
        skipped_repos+=("$short")
        echo ""
        continue
    fi

    if [[ "$DRYRUN" == true ]]; then
        for cmd in "${commands[@]}"; do
            echo -e "  ${DIM}[dryrun] $cmd${RESET}"
        done
        echo ""
        continue
    fi

    repo_failed=false
    for cmd in "${commands[@]}"; do
        echo -e "  ${YELLOW}▸ $cmd${RESET}"
        if ! (cd "$repo" && eval "$cmd"); then
            echo -e "  ${RED}✗ failed: $cmd${RESET}"
            repo_failed=true
            break
        fi
    done

    if [[ "$repo_failed" == true ]]; then
        (( failed++ )) || true
        failed_repos+=("$short")
    else
        (( succeeded++ )) || true
        echo -e "  ${GREEN}✓ done${RESET}"
    fi
    echo ""
done

if [[ "$DRYRUN" == true ]]; then
    exit 0
fi

echo -e "${BOLD}━━━ Summary ━━━${RESET}"
echo -e "${GREEN}${succeeded} updated${RESET}"
if [[ $failed -gt 0 ]]; then
    echo -e "${RED}${failed} failed:${RESET}"
    for r in "${failed_repos[@]}"; do
        echo -e "  ${RED}${r}${RESET}"
    done
fi
if [[ ${#skipped_repos[@]} -gt 0 ]]; then
    echo -e "${DIM}${#skipped_repos[@]} skipped (no commands configured)${RESET}"
fi
