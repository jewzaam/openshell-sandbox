#!/usr/bin/env bash
# Generated By: Claude Code (Claude Opus 4.6)
set -euo pipefail

OPEN_CODE=false
OPEN_CCODE=false

show_help() {
    cat <<'EOF'
Usage: gwt [OPTIONS] <pr-number|branch-name>

Create or reuse a git worktree for a PR or branch under git-worktrees/.

Arguments:
  pr-number      GitHub PR number — checks out the PR via gh
  branch-name    Branch name — creates or tracks the branch

Options:
  --code         Open the worktree in VS Code
  --ccode        Open the worktree in Claude Code
  --help, -h     Show this help message

Examples:
  gwt 42                  Check out PR #42
  gwt my-feature          Create/reuse branch worktree
  gwt --code 42           Check out PR #42 and open in VS Code
  gwt --ccode my-feature  Create branch worktree and open in Claude Code
EOF
}

while [[ $# -gt 0 ]]; do
    case "$1" in
        --help|-h) show_help; exit 0 ;;
        --code) OPEN_CODE=true; shift ;;
        --ccode) OPEN_CCODE=true; shift ;;
        -*) echo "Unknown option: $1" >&2; exit 1 ;;
        *) ARG="$1"; shift ;;
    esac
done

if [ -z "${ARG:-}" ]; then
    show_help
    exit 1
fi

# Detect whether argument is a PR number (all digits) or a branch name
if [[ "$ARG" =~ ^[0-9]+$ ]]; then
    MODE="pr"
    PR="$ARG"
    DIR="git-worktrees/${PR}"
else
    MODE="branch"
    BRANCH="$ARG"
    DIR="git-worktrees/${BRANCH}"
fi

if [ -d "$DIR" ]; then
    echo "Worktree already exists at $DIR, reusing..."
else
    if [ "$MODE" = "pr" ]; then
        git worktree add "$DIR" --detach
    else
        # Check if branch exists locally or in remote
        if git show-ref --verify --quiet "refs/heads/${BRANCH}" 2>/dev/null; then
            git worktree add "$DIR" "$BRANCH"
        elif git show-ref --verify --quiet "refs/remotes/origin/${BRANCH}" 2>/dev/null; then
            git worktree add "$DIR" --track -b "$BRANCH" "origin/${BRANCH}"
        else
            git worktree add -b "$BRANCH" "$DIR"
        fi
    fi
fi

cd "$DIR"

if [ "$MODE" = "pr" ]; then
    if ! gh pr checkout "$PR" --force 2>&1; then
        PR_BRANCH=$(gh pr view "$PR" --json headRefName -q '.headRefName')
        echo ""
        echo "ERROR: Branch '$PR_BRANCH' is already checked out in another worktree."
        echo "Switch to a different branch in your main worktree first, then retry."
        exit 1
    fi
    echo "PR $PR checked out in $DIR"
else
    echo "Branch $BRANCH ready in $DIR"
fi

if [ "$OPEN_CODE" = true ]; then
    code .
fi

if [ "$OPEN_CCODE" = true ]; then
    ccode .
fi
