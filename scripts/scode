#!/usr/bin/env bash
# Generated By: Claude Code (Claude Opus 4.6)
#
# Open a sandbox-backed VS Code session for code review.
# Creates or reconnects to a sandbox named <repo>-<ref>, with
# VS Code tasks that auto-launch Claude inside the sandbox.

set -euo pipefail

SANDBOX_SH="${SANDBOX_SH:-${HOME}/source/openshell-sandbox/scripts/sandbox.sh}"
SANDBOXES_DIR="${HOME}/sandboxes"

if [[ "${1:-}" == "--help" ]] || [[ "${1:-}" == "-h" ]]; then
    cat << 'EOF'
Usage: scode [--name NAME | SOURCE_PATH [REF]]

Open a directory in VS Code backed by an OpenShell sandbox running Claude.

Modes:
  scode SOURCE_PATH [REF]    Auto-name sandbox <repo>-<ref>, clone repo
  scode --name NAME          Custom name, no repos (add with sandbox.sh --add-repo)

Arguments:
  SOURCE_PATH    Path to local git repo (e.g., ~/source/nexus)
  REF            Branch, PR, tag, or SHA (default: repo's default branch)

Examples:
  scode ~/source/nexus pr/1176
  scode ~/source/nexus
  scode --name review-workspace
EOF
    exit 0
fi

if [[ $# -lt 1 ]]; then
    echo "error: requires --name NAME or SOURCE_PATH" >&2
    echo "usage: scode [--name NAME | SOURCE_PATH [REF]]" >&2
    exit 1
fi

# --- Name-only mode: custom sandbox, no repos ---
if [[ "$1" == "--name" ]]; then
    [[ $# -ge 2 ]] || { echo "error: --name requires NAME" >&2; exit 1; }
    sandbox_name="$2"
    sandbox_dir="${SANDBOXES_DIR}/${sandbox_name}"
    mkdir -p "${sandbox_dir}/.vscode"

    if [[ ! -f "${sandbox_dir}/.vscode/tasks.json" ]]; then
        cat > "${sandbox_dir}/.vscode/tasks.json" << TASKS
{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "sandbox",
      "type": "shell",
      "command": "${SANDBOX_SH} --ensure ${sandbox_name}",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "group": "sandbox-dev"
      },
      "runOptions": {"runOn": "folderOpen"}
    },
    {
      "label": "bash",
      "type": "shell",
      "command": "exec bash -li",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "group": "sandbox-dev"
      },
      "runOptions": {"runOn": "folderOpen"}
    }
  ]
}
TASKS
    fi

    code "${sandbox_dir}"
    exit 0
fi

# --- Repo mode: auto-name from repo + ref ---
source_path="$(realpath "$1")"

if [[ ! -d "$source_path/.git" ]]; then
    echo "error: ${source_path} is not a git repository" >&2
    exit 1
fi

if [[ $# -ge 2 ]]; then
    ref="$2"
else
    ref="$(git -C "$source_path" symbolic-ref refs/remotes/origin/HEAD 2>/dev/null | sed 's|refs/remotes/origin/||')" || true
    if [[ -z "$ref" ]]; then
        echo "error: cannot detect default branch (no origin/HEAD). Specify REF explicitly" >&2
        exit 1
    fi
fi

repo_name="$(basename "$source_path")"
ref_normalized="${ref//\//-}"
sandbox_name="${repo_name}-${ref_normalized}"

repo_url="$(git -C "$source_path" remote get-url origin 2>/dev/null)" || {
    echo "error: no origin remote in ${source_path}" >&2
    exit 1
}

sandbox_dir="${SANDBOXES_DIR}/${sandbox_name}"
mkdir -p "${sandbox_dir}/.vscode"

if [[ ! -f "${sandbox_dir}/.vscode/tasks.json" ]]; then
    cat > "${sandbox_dir}/.vscode/tasks.json" << TASKS
{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "sandbox",
      "type": "shell",
      "command": "${SANDBOX_SH} --ensure ${sandbox_name} --repo ${repo_url} --ref ${ref} --source-dir ${source_path}",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "group": "sandbox-dev"
      },
      "runOptions": {"runOn": "folderOpen"}
    },
    {
      "label": "bash",
      "type": "shell",
      "command": "exec bash -li",
      "isBackground": true,
      "problemMatcher": [],
      "presentation": {
        "reveal": "always",
        "panel": "new",
        "group": "sandbox-dev"
      },
      "runOptions": {"runOn": "folderOpen"}
    }
  ]
}
TASKS
fi

code "${sandbox_dir}"
